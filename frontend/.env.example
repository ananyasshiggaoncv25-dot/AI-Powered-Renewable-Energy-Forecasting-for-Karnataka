# Browser calls this origin; Vite dev server proxies /api → FastAPI (see vite.config.ts).
VITE_API_BASE_URL=/api

# For production deployment (e.g., Netlify), set to your deployed API URL:
# VITE_API_BASE_URL=https://your-api-service.com

# Backend URL for the proxy (not exposed to the client).
FORECAST_API_PROXY_TARGET=http://127.0.0.1:8000

# Alternative: call FastAPI directly (requires CORS_ALLOW_ORIGINS on the API).
# VITE_API_BASE_URL=http://127.0.0.1:8000
